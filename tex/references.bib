@article{Yuzhe2023_FrequencyScanning,
  author   = {Zhang, Yuzhe and Tumturk, Deniz Aybas and Bekker, Hendrik and Budker, Dmitry and Kimball, Derek F. Jackson and Sushkov, Alexander O. and Wickenbrock, Arne},
  title    = {{Frequency-Scanning Considerations in Axionlike Dark Matter Spin-Precession Experiments}},
  journal  = {Annalen der Physik},
  volume   = {536},
  number   = {1},
  pages    = {2300223},
  keywords = {axions, axionlike particles, dark matter, NMR, spin precession},
  url      = {https://onlinelibrary.wiley.com/doi/abs/10.1002/andp.202300223},
  abstract = {Abstract Galactic dark matter may consist of axionlike particles (ALPs) that can be described as an “ultralight bosonic field” oscillating at the ALP Compton frequency. The ALP field can be searched for using nuclear magnetic resonance (NMR), where resonant precession of spins of a polarized sample can be sensitively detected. The ALP mass to which the experiment is sensitive is scanned by sweeping the bias magnetic field. The scanning either results in detection of ALP dark matter or rules out ALP dark matter with sufficiently strong couplings to nuclear spins over the range of ALP masses corresponding to the covered span of Larmor frequencies. In this work, scanning strategies are analyzed with the goal of optimizing the parameter-space coverage via a proper choice of experimental parameters (e.g., the effective transverse relaxation time).},
  year     = {2024}
}


